# ==========================================
# SERVER CONFIGURATION
# ==========================================
# Port number where the Node.js backend will run
PORT=5000

# ==========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
# Your Postgres username (usually 'postgres')
DB_USER=postgres
# Host where the DB is running (localhost for local development)
DB_HOST=localhost
# Name of the database you created for this project
DB_NAME=society_db
# Password for your Postgres user
DB_PASSWORD=password
# Port where Postgres is running (default is 5432)
DB_PORT=5432

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
# Any random, long string used to securely sign JWT tokens for Login/Reset Passwords
JWT_SECRET=super_secret_jwt_key_here

# ==========================================
# PAYMENT INTEGRATION (Razorpay)
# ==========================================
# Get these by logging into the Razorpay Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=your_razorpay_key_here
RAZORPAY_SECRET=your_razorpay_secret_here

# ==========================================
# GOOGLE OAUTH CONFIGURATION
# ==========================================
# Get this from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id_here
